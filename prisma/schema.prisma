generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  empresa   String
  createdAt DateTime @default(now())

  apiKey  ApiKey?
  uploads Upload[]
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   // "claude" | "gpt"
  encryptedKey String
  createdAt    DateTime @default(now())
}

model Upload {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename  String
  sessionId String   @unique
  createdAt DateTime @default(now())
}
